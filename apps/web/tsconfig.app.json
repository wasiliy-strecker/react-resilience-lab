{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@react-resilience/command-outbox": [
        "packages/command-outbox/src/index.ts"
      ],
      "@react-resilience/command-outbox/react": [
        "packages/command-outbox/src/react.ts"
      ],
      "@react-resilience/contracts": ["packages/contracts/src/index.ts"]
    },
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src"]
}
